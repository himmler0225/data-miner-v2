# ── YouTube ───────────────────────────────────────────────────────────────────
YOUTUBE_BASE_URL=https://www.youtube.com
YOUTUBE_API_BASE=https://www.youtube.com/youtubei/v1

# ── Auth ──────────────────────────────────────────────────────────────────────
API_KEYS=your-api-key-here

# ── Ingest (youtube-api) ──────────────────────────────────────────────────────
INGEST_API_URL=http://localhost:3000
INGEST_SERVICE_KEY=change-me-strong-secret

# ── NestJS WebSocket ──────────────────────────────────────────────────────────
NESTJS_WS_URL=http://localhost:3000
CRAWLER_WS_KEY=change-me

# ── TikTok ────────────────────────────────────────────────────────────────────
TIKAP_API_KEY=your-tikap-key

# ── Scheduler ─────────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=false
BATCH_CONCURRENCY=3

# ── Supabase (remote config) ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Proxy, rate limit được quản lý trong Supabase config table
